# Tableau server
TABLEAU_SERVER_URL=https://tableau.example.com
TABLEAU_SITE_ID=
TABLEAU_TOKEN_NAME=replace_with_token_name
TABLEAU_TOKEN_VALUE=replace_with_token_secret

# Admin bootstrap (required for first login)
# Option A: provide plain password (will be hashed and stored)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Option B: provide pre-hashed password instead of ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=

# Optional custom path for env-user mapping file
# USERLIST_ENV_PATH=userlist.env
